# Server Configuration
PORT=8010
HOST=http://localhost:8010
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://postgres:grep3@localhost:5433/grep3

# Redis (for job queue)
REDIS_URL=redis://localhost:6379

# Twitter API v2 Credentials
# Get these from https://developer.twitter.com/
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# Your Twitter username (without @) - used to fetch your tweet history
TWITTER_USERNAME=your_username

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# Posting Configuration
# How many tweets to generate per day (can be overridden)
TWEETS_PER_DAY=3

# Minimum hours between posts (prevents spam)
MIN_HOURS_BETWEEN_POSTS=4

# Maximum tweets to analyze for voice learning
MAX_TWEETS_TO_ANALYZE=500

# Topics to focus on (comma-separated)
# Example: software development,crypto,web3,AI,startups
TOPICS=software development,crypto,web3

# Auto-post mode: if true, posts automatically; if false, queues for review
AUTO_POST=false
