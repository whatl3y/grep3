{
  "name": "@grep3/twitter-bot",
  "version": "0.0.1",
  "description": "AI-powered Twitter bot that generates authentic, high-engagement posts in your voice",
  "repository": {
    "type": "git",
    "url": "https://github.com/whatl3y/grep3"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/webServer.js",
    "dev": "ts-node src/webServer.ts",
    "resque:worker": "node dist/resqueWorker",
    "resque:scheduler": "node dist/resqueScheduler",
    "analyze": "node dist/tasks/analyzeTweets.js",
    "generate": "node dist/tasks/generateTweet.js",
    "migrate": "node dist/tasks/migrate.js",
    "resque:queue-job": "node dist/tasks/resque/queueJob.js",
    "resque:queue-length": "node dist/tasks/resque/getQueueLength.js",
    "resque:queued-jobs": "node dist/tasks/resque/getQueuedJobs.js",
    "resque:failed": "node dist/tasks/resque/retryFailedJobs.js",
    "resque:clear-queue": "node dist/tasks/resque/clearQueue.js",
    "resque:clean-workers": "node dist/tasks/resque/cleanOldWorkers.js",
    "resque:delete-by-function": "node dist/tasks/resque/deleteByFunction.js",
    "test": "mocha --require ts-node/register --recursive --parallel './src/**/*.spec.ts'"
  },
  "author": "Lance Whatley <lance@moontography.com>",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@grep3/core": "workspace:*",
    "bunyan": "^1.8.15",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "ioredis": "^5.8.2",
    "kysely": "^0.28.8",
    "minimist": "^1.2.8",
    "node-resque": "^9.3.8",
    "pg": "^8.16.3",
    "pug": "^3.0.3",
    "twitter-api-v2": "^1.18.2"
  },
  "devDependencies": {
    "@types/bunyan": "^1.8.11",
    "@types/express": "^5.0.6",
    "@types/minimist": "^1.2.5",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
