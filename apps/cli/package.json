  "description": "CLI for interacting with grep3 APIs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/grep3/grep3",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/grep3/grep3#readme",
  "bugs": {
