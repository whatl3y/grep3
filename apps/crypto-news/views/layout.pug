doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= title || 'Crypto News Daily'
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet")
    link(rel="stylesheet" href="/styles/main.css")
  body
    .container
      header.site-header
        h1
          a(href="/") Crypto News Daily
        p.tagline AI-powered summaries of the day's top crypto events

      main
        block content

      footer.site-footer
        p Summaries generated every 4 hours using AI
        p Data sourced from major crypto news outlets
