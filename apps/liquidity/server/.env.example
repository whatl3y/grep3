HOST=http://localhost:8095
PORT=8095
LOG_LEVEL=debug
REDIS_URL=redis://localhost:6379

# =============================================================================
# RPC URLs - Configure one or more chains
#
# All chains have public RPC fallbacks, but these are rate-limited and may be
# unreliable for production use. For best results, configure dedicated RPCs:
#
# Recommended providers:
# - Alchemy: https://www.alchemy.com/ (free tier available)
# - Infura: https://infura.io/ (free tier available)
# - QuickNode: https://www.quicknode.com/
# - Ankr: https://www.ankr.com/rpc/
#
# If an RPC URL is not set, the app falls back to a public RPC.
# =============================================================================

# Ethereum Mainnet (Chain ID: 1)
# Fallback: https://eth.llamarpc.com
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Arbitrum One (Chain ID: 42161)
# Fallback: https://arb1.arbitrum.io/rpc
# ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Optimism (Chain ID: 10)
# Fallback: https://mainnet.optimism.io
# OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Polygon (Chain ID: 137)
# Fallback: https://polygon-rpc.com
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Base (Chain ID: 8453)
# Fallback: https://mainnet.base.org
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# BNB Chain (Chain ID: 56)
# Fallback: https://bsc-dataseed.binance.org
# BSC_RPC_URL=https://bsc-dataseed.binance.org

# =============================================================================
# Other Configuration
# =============================================================================

# Price range configuration (percentage above/below current price)
# Default is 50% for comprehensive depth view
PRICE_RANGE_PERCENT=50

# Cache TTL in seconds (default 5 minutes)
CACHE_TTL=300
