# Trustless Agent Environment Configuration
# Copy this file to .env and fill in your values

# ==============================================================================
# REQUIRED: OpenAI API Configuration
# ==============================================================================
# Your OpenAI API key for the agent's language model
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ==============================================================================
# REQUIRED FOR ROFL DEPLOYMENT: Blockchain RPC
# ==============================================================================
# Ethereum RPC URL for ERC-8004 registration
# Recommended: Use Sepolia testnet for development
# Example: https://sepolia.infura.io/v3/YOUR_INFURA_KEY
RPC_URL=https://sepolia.infura.io/v3/your-infura-project-id

# ==============================================================================
# REQUIRED FOR ROFL DEPLOYMENT: IPFS Storage
# ==============================================================================
# Pinata JWT for IPFS storage (used for ERC-8004 metadata)
# Get one at: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=your-pinata-jwt-token

# ==============================================================================
# OPTIONAL: EVM/Blockchain Configuration
# ==============================================================================
# Private key for signing transactions (required for transfers/swaps)
# WARNING: Keep this secret! Never commit to version control.
# EVM_PRIVATE_KEY=your-wallet-private-key-here

# Oasis Sapphire RPC URL (defaults to mainnet if not set)
# Mainnet: https://sapphire.oasis.io
# Testnet: https://testnet.sapphire.oasis.io
EVM_PROVIDER_URL=https://sapphire.oasis.io

# ==============================================================================
# OPTIONAL: Application Configuration
# ==============================================================================
# Node environment (development, production)
NODE_ENV=development

# PGLite data directory for persistent storage
PGLITE_DATA_DIR=./data

# ==============================================================================
# ROFL SPECIFIC (Set via CLI, not in .env)
# ==============================================================================
# The following secrets should be set using the Oasis CLI for end-to-end encryption:
#
# echo -n "$OPENAI_API_KEY" | oasis rofl secret set OPENAI_API_KEY -
# echo -n "$RPC_URL" | oasis rofl secret set RPC_URL -
# echo -n "$PINATA_JWT" | oasis rofl secret set PINATA_JWT -
#
# These secrets are encrypted and only accessible within the TEE.
