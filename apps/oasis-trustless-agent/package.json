{
  "name": "@grep3/oasis-trustless-agent",
  "version": "0.1.0",
  "description": "Trustless AI agent built on ElizaOS with Oasis ROFL for TEE execution and ERC-8004 verification",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/whatl3y/grep3"
  },
  "scripts": {
    "start": "elizaos start --character characters/trustless.json",
    "dev": "elizaos start --character characters/trustless.json",
    "rofl:init": "oasis rofl init",
    "rofl:create": "oasis rofl create --network testnet",
    "rofl:build": "oasis rofl build",
    "rofl:deploy": "oasis rofl deploy",
    "rofl:show": "oasis rofl show",
    "rofl:logs": "oasis rofl machine logs",
    "rofl:status": "oasis rofl machine show",
    "rofl:top-up": "oasis rofl machine top-up --term hour --term-count 4",
    "docker:build": "docker compose build",
    "docker:push": "docker compose push",
    "secret:openai": "echo -n \"$OPENAI_API_KEY\" | oasis rofl secret set OPENAI_API_KEY -",
    "secret:rpc": "echo -n \"$RPC_URL\" | oasis rofl secret set RPC_URL -",
    "secret:pinata": "echo -n \"$PINATA_JWT\" | oasis rofl secret set PINATA_JWT -"
  },
  "author": "Lance Whatley <lance@moontography.com>",
  "license": "MIT",
  "dependencies": {
    "@elizaos/cli": "^1.0.0",
    "@elizaos/core": "^1.0.0",
    "@elizaos/plugin-bootstrap": "^1.0.0",
    "@elizaos/plugin-openai": "^1.0.0",
    "@elizaos/plugin-evm": "^1.0.0",
    "@elizaos/plugin-sql": "^1.0.0",
    "@oasisprotocol/sapphire-paratime": "^1.3.0",
    "ethers": "^6.13.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
