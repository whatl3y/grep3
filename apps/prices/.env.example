# Server
PORT=8097
HOST=http://localhost:8097

# Redis (required for caching)
REDIS_URL=redis://localhost:6379

# CoinGecko (enabled by default)
# Demo API key: free tier (get at https://www.coingecko.com/en/api/pricing)
# Pro API key: paid tier (set COINGECKO_PRO=true)
COINGECKO_ENABLED=true
COINGECKO_API_KEY=
COINGECKO_PRO=false

# CoinMarketCap (optional backup)
CMC_ENABLED=false
CMC_API_KEY=

# Jupiter for Solana (enabled by default)
# API key required - get one at https://portal.jup.ag
JUPITER_ENABLED=true
JUPITER_API_KEY=

# Cache TTL in seconds
CACHE_TTL=60

# RPC URLs (optional, uses public defaults)
ETH_RPC_URL=
BASE_RPC_URL=
BSC_RPC_URL=
ARBITRUM_RPC_URL=
AVALANCHE_RPC_URL=
POLYGON_RPC_URL=
SOLANA_RPC_URL=

# Logging
LOG_LEVEL=info
