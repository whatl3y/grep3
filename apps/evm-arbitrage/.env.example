# Logging (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://postgres:grep3@localhost:5433/grep3

# Redis
REDIS_URL=redis://localhost:6379

# RPC URLs (at least one required)
ETH_RPC_URL=
ARBITRUM_RPC_URL=
BASE_RPC_URL=
BSC_RPC_URL=
POLYGON_RPC_URL=
OPTIMISM_RPC_URL=
AVALANCHE_RPC_URL=

# WebSocket RPC URLs (optional, for faster block updates)
ETH_RPC_URL_WS=
ARBITRUM_RPC_URL_WS=
BASE_RPC_URL_WS=
BSC_RPC_URL_WS=
POLYGON_RPC_URL_WS=
OPTIMISM_RPC_URL_WS=
AVALANCHE_RPC_URL_WS=

# Private RPC URLs (optional, for tx execution only - e.g., Flashbots, private mempool)
# If set, transactions will be sent via this RPC while reads use the regular RPC
ETH_PRIVATE_RPC_URL=
ARBITRUM_PRIVATE_RPC_URL=
BASE_PRIVATE_RPC_URL=
BSC_PRIVATE_RPC_URL=
POLYGON_PRIVATE_RPC_URL=
OPTIMISM_PRIVATE_RPC_URL=
AVALANCHE_PRIVATE_RPC_URL=

# Execution wallet private key (required for executing arbitrage)
PRIVATE_KEY=

# Arbitrage contract addresses (set after deployment)
ARBITRAGE_CONTRACT_ETH=
ARBITRAGE_CONTRACT_ARBITRUM=
ARBITRAGE_CONTRACT_BASE=
ARBITRAGE_CONTRACT_BSC=
ARBITRAGE_CONTRACT_POLYGON=
ARBITRAGE_CONTRACT_OPTIMISM=
ARBITRAGE_CONTRACT_AVALANCHE=

# Execution settings
EXECUTION_ENABLED=false
# MIN_PROFIT_WEI is an optional pre-filter - contract will revert if not profitable anyway
MIN_PROFIT_WEI=1000000000
# Bribe to block producer in basis points (0-10000, where 10000 = 100% of profit)
BRIBE_BPS=0
# Flash loan provider: "balancer" or "morpho"
FLASH_LOAN_PROVIDER=morpho
